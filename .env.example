# Copy to .env and set values. Never commit .env to Git.
# On server: set these in your hosting dashboard or shell.

# Required for production
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Optional: static files (defaults to core/staticfiles)
# STATIC_ROOT=/var/www/yourproject/staticfiles

# Email (optional; leave empty to disable)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
